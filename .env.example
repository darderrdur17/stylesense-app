# StyleSense — environment template (never commit real secrets)
#
# Prisma CLI only auto-loads `.env` (not `.env.local`). Next.js loads `.env` then `.env.local`.
# Recommended split:
#   `.env`          → DATABASE_URL (so `npx prisma db push` works)
#   `.env.local`    → AUTH_SECRET and optional API keys
#
# Copy values into those files, or merge into one `.env.local` and run:
#   DATABASE_URL="..." npx prisma db push

# ---------------------------------------------------------------------------
# Required — database
# ---------------------------------------------------------------------------
#
# Supabase (two URLs — both from the dashboard with "Use IPv4 connection (Shared Pooler)" if needed):
#   DATABASE_URL  = Transaction pooler, port 6543 + ?pgbouncer=true&connection_limit=1&sslmode=require
#   DIRECT_URL      = Session pooler, same pooler host, port 5432 + ?sslmode=require
# Prisma `db push` / migrations use DIRECT_URL. Using only the transaction pooler for schema changes can hang.
# If P1001 on port 5432, try another network (e.g. phone hotspot) for `npm run db:push`.
#
# Neon / local Postgres: set DATABASE_URL and DIRECT_URL to the SAME connection string.
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# ---------------------------------------------------------------------------
# Required — auth (NextAuth / Auth.js)
# Generate: openssl rand -base64 32
# ---------------------------------------------------------------------------
AUTH_SECRET=""

# Production / Vercel: canonical site URL (no trailing slash)
# AUTH_URL="https://your-app.vercel.app"

# Show “Fill demo email & password” on /login (set true on Vercel to help testers)
# NEXT_PUBLIC_SHOW_DEMO_LOGIN="true"

# Optional: custom password for seeded demo user (default in src/lib/demo-account.ts)
# DEMO_SEED_PASSWORD=""

# Skip creating demo user: SEED_DEMO_ACCOUNT=false

# ---------------------------------------------------------------------------
# Optional — Vercel Blob (recommended for production uploads)
# Free allowance on Vercel Hobby; see Vercel Blob pricing.
# https://vercel.com/docs/storage/vercel-blob
# ---------------------------------------------------------------------------
# BLOB_READ_WRITE_TOKEN=""

# ---------------------------------------------------------------------------
# Optional — Garment AI (set at least one for “Detect garment with AI”)
# Gemini is used first when both are set.
# Google AI Studio: free tier with rate limits — https://aistudio.google.com/apikey
# OpenAI: paid API; skip if you only use Gemini.
# ---------------------------------------------------------------------------
# GEMINI_API_KEY=""
# GEMINI_GARMENT_MODEL="gemini-2.0-flash"

# OPENAI_API_KEY=""
# OPENAI_GARMENT_MODEL="gpt-4o-mini"
